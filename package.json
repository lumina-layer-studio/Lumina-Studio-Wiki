{
  "name": "lumina-studio-wiki",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/lumina-layer-studio/Lumina-Studio-Wiki.git"
  },
  "scripts": {
    "build": "docusaurus build",
    "postbuild": "node scripts/write-pages-control-files.mjs",
    "clear": "docusaurus clear",
    "docusaurus": "docusaurus",
    "serve": "docusaurus serve",
    "start": "docusaurus start",
    "test:edge": "node --test tests/*.test.mjs",
    "test:guard": "python3 -m unittest discover tests -p 'test_*.py' -v",
    "validate:media": "node scripts/media-contributions.mjs",
    "test:public": "pnpm test:guard && pnpm test:edge && pnpm validate:media",
    "typecheck": "tsc --noEmit",
    "write-translations": "docusaurus write-translations"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@easyops-cn/docusaurus-search-local": "0.55.1",
    "@mdx-js/react": "3.1.1",
    "artalk": "2.9.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "pnpm@11.9.0"
}
